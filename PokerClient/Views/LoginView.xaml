<UserControl x:Class="BlackjackGame.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/CasinoStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid>
        <!-- Background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1117" Offset="0"/>
                <GradientStop Color="#161B22" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <!-- Decorative Background Elements -->
        <Canvas IsHitTestVisible="False" Opacity="0.1">
            <TextBlock Text="♠" FontFamily="Segoe UI Symbol" FontSize="200" 
                       Canvas.Left="50" Canvas.Top="100" Foreground="#D4AF37"/>
            <TextBlock Text="♥" FontFamily="Segoe UI Symbol" FontSize="150" 
                       Canvas.Right="100" Canvas.Top="50" Foreground="#D4AF37"/>
            <TextBlock Text="♦" FontFamily="Segoe UI Symbol" FontSize="180" 
                       Canvas.Left="100" Canvas.Bottom="50" Foreground="#D4AF37"/>
            <TextBlock Text="♣" FontFamily="Segoe UI Symbol" FontSize="160" 
                       Canvas.Right="50" Canvas.Bottom="100" Foreground="#D4AF37"/>
        </Canvas>
        
        <!-- Main Content -->
        <Border CornerRadius="20" MaxWidth="450" MaxHeight="800" 
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="40">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#20FFFFFF" Offset="0"/>
                    <GradientStop Color="#10FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            
            <StackPanel>
                <!-- Logo -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="♠ ♥ ♦ ♣" FontFamily="Segoe UI Symbol" FontSize="32"
                               Foreground="{StaticResource GoldAccentBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="ROYAL CASINO" FontSize="32" FontWeight="Light"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"
                               FontFamily="Segoe UI Light"/>
                    <TextBlock Text="Online Multiplayer" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
                
                <!-- Server Connection -->
                <Border Background="#15FFFFFF" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Server" Foreground="{StaticResource TextSecondaryBrush}" 
                                   FontSize="11" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ServerUrlBox" Style="{StaticResource PremiumTextBox}"
                                     Text="https://poker-server-vi5l.onrender.com/gamehub" FontSize="11"/>
                            <Button x:Name="ConnectButton" Grid.Column="1" Content="Connect" 
                                    Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"
                                    Click="ConnectButton_Click" Width="80" FontSize="11"/>
                        </Grid>
                        <TextBlock x:Name="ConnectionStatus" Text="Not connected" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   FontSize="10" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Auth Forms (initially disabled until connected) -->
                <StackPanel x:Name="AuthPanel" IsEnabled="False" Opacity="0.5">
                    <!-- Tab Toggle -->
                    <Border Background="#20FFFFFF" CornerRadius="25" Padding="4" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <RadioButton x:Name="LoginTab" Content="Sign In" IsChecked="True"
                                         Style="{StaticResource ModeToggleButton}" GroupName="AuthTab"
                                         Checked="LoginTab_Checked"/>
                            <RadioButton x:Name="RegisterTab" Content="Register"
                                         Style="{StaticResource ModeToggleButton}" GroupName="AuthTab"
                                         Checked="RegisterTab_Checked"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Login Form -->
                    <StackPanel x:Name="LoginForm">
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Username" Foreground="{StaticResource TextSecondaryBrush}" 
                                       FontSize="12" Margin="0,0,0,8"/>
                            <TextBox x:Name="LoginUsernameBox" Style="{StaticResource PremiumTextBox}"/>
                        </StackPanel>
                        
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Password" Foreground="{StaticResource TextSecondaryBrush}" 
                                       FontSize="12" Margin="0,0,0,8"/>
                            <PasswordBox x:Name="LoginPasswordBox" Style="{StaticResource PremiumPasswordBox}"/>
                        </StackPanel>
                        
                        <Button Content="SIGN IN" Style="{StaticResource PremiumButton}" 
                                Margin="0,20,0,0" Click="LoginButton_Click"/>
                    </StackPanel>
                    
                    <!-- Register Form -->
                    <StackPanel x:Name="RegisterForm" Visibility="Collapsed">
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Username" Foreground="{StaticResource TextSecondaryBrush}" 
                                       FontSize="12" Margin="0,0,0,8"/>
                            <TextBox x:Name="RegisterUsernameBox" Style="{StaticResource PremiumTextBox}"/>
                        </StackPanel>
                        
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Email" Foreground="{StaticResource TextSecondaryBrush}" 
                                       FontSize="12" Margin="0,0,0,8"/>
                            <TextBox x:Name="RegisterEmailBox" Style="{StaticResource PremiumTextBox}"/>
                        </StackPanel>
                        
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Password" Foreground="{StaticResource TextSecondaryBrush}" 
                                       FontSize="12" Margin="0,0,0,8"/>
                            <PasswordBox x:Name="RegisterPasswordBox" Style="{StaticResource PremiumPasswordBox}"/>
                        </StackPanel>
                        
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Confirm Password" Foreground="{StaticResource TextSecondaryBrush}" 
                                       FontSize="12" Margin="0,0,0,8"/>
                            <PasswordBox x:Name="RegisterConfirmPasswordBox" Style="{StaticResource PremiumPasswordBox}"/>
                        </StackPanel>
                        
                        <Button Content="CREATE ACCOUNT" Style="{StaticResource PremiumButton}" 
                                Margin="0,20,0,0" Click="RegisterButton_Click"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Error Message -->
                <TextBlock x:Name="ErrorMessage" Foreground="#E74C3C" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,15,0,0" TextWrapping="Wrap"/>
                
                <!-- Guest Login (offline mode) -->
                <Button Content="Play Offline (Guest)" Style="{StaticResource SecondaryButton}" 
                        Margin="0,15,0,0" Click="GuestButton_Click" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
