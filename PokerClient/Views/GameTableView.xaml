<UserControl x:Class="BlackjackGame.Views.GameTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BlackjackGame.Views">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/CasinoStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid x:Name="MainGrid">
        <!-- Dark Background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1117" Offset="0"/>
                <GradientStop Color="#161B22" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#20FFFFFF" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Game Mode Toggle -->
                <Border Grid.Column="0" Background="#15FFFFFF" CornerRadius="20" 
                        Padding="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="BlackjackMode" Content="Blackjack" IsChecked="True"
                                     Style="{StaticResource ModeToggleButton}" GroupName="GameMode"
                                     Checked="BlackjackMode_Checked"/>
                        <RadioButton x:Name="PokerMode" Content="Poker"
                                     Style="{StaticResource ModeToggleButton}" GroupName="GameMode"
                                     Checked="PokerMode_Checked"/>
                    </StackPanel>
                </Border>
                
                <!-- Logo -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="♠" FontFamily="Segoe UI Symbol" FontSize="24" 
                               Foreground="{StaticResource GoldAccentBrush}" Margin="0,0,10,0"/>
                    <TextBlock Text="ROYAL CASINO" FontSize="20" FontWeight="Light"
                               Foreground="White" FontFamily="Segoe UI Light" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- User Info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <!-- Balance -->
                    <Border Background="#20D4AF37" CornerRadius="20" Padding="15,8" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock x:Name="BalanceDisplay" Text="$1,000" FontSize="14"
                                       Foreground="{StaticResource GoldAccentBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- User Avatar and Name -->
                    <Border Background="#30FFFFFF" CornerRadius="20" Padding="8,6,15,6">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="28" Height="28" Margin="0,0,10,0">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#50C878" Offset="0"/>
                                        <GradientStop Color="#2E8B57" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock x:Name="UsernameDisplay" Text="Player" FontSize="14"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Bonus Button -->
                    <Button x:Name="BonusButton" Content="🎁 Bonus" Margin="15,0,0,0"
                            Style="{StaticResource SecondaryButton}" Padding="12,6"
                            Click="BonusButton_Click"/>
                    
                    <!-- Logout -->
                    <Button x:Name="LogoutButton" Content="↩" FontSize="18" Margin="10,0,0,0"
                            Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                            BorderThickness="0" Cursor="Hand" ToolTip="Logout"
                            Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Game Table Area -->
        <Grid Grid.Row="1" Margin="40">
            <!-- Poker Table (Ellipse) -->
            <Ellipse x:Name="TableSurface" Stretch="Fill" Margin="20">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" 
                                         RadiusX="0.6" RadiusY="0.6">
                        <GradientStop Color="#1E8B5E" Offset="0"/>
                        <GradientStop Color="#0D4F3C" Offset="0.7"/>
                        <GradientStop Color="#082A20" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <DropShadowEffect Color="#50C878" BlurRadius="50" ShadowDepth="0" Opacity="0.3"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <!-- Table Border -->
            <Ellipse Stretch="Fill" Margin="20" StrokeThickness="8">
                <Ellipse.Stroke>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#5D4037" Offset="0"/>
                        <GradientStop Color="#8D6E63" Offset="0.5"/>
                        <GradientStop Color="#5D4037" Offset="1"/>
                    </LinearGradientBrush>
                </Ellipse.Stroke>
            </Ellipse>
            
            <!-- Inner Table Rim -->
            <Ellipse Stretch="Fill" Margin="35" Stroke="#30D4AF37" StrokeThickness="2" 
                     StrokeDashArray="10,5"/>
            
            <!-- Game Content -->
            <Grid x:Name="GameContent" Margin="60">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Dealer Area -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="D E A L E R" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,10" FontWeight="Medium"/>
                    
                    <!-- Dealer Cards -->
                    <StackPanel x:Name="DealerCardsPanel" Orientation="Horizontal" 
                                HorizontalAlignment="Center"/>
                    
                    <!-- Dealer Hand Value -->
                    <Border x:Name="DealerValueBadge" Background="#40000000" CornerRadius="15" 
                            Padding="15,6" Margin="0,10,0,0" HorizontalAlignment="Center"
                            Visibility="Collapsed">
                        <TextBlock x:Name="DealerHandValue" Text="0" FontSize="16"
                                   Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                
                <!-- Center Area (Message, Pot, Community Cards) -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Game Phase Message -->
                    <Border x:Name="MessageBorder" Background="#50000000" CornerRadius="10" 
                            Padding="25,12" Margin="0,10">
                        <TextBlock x:Name="GameMessage" Text="Place Your Bet" FontSize="18"
                                   Foreground="{StaticResource GoldAccentBrush}" FontWeight="Medium"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    
                    <!-- Community Cards (for Poker) -->
                    <StackPanel x:Name="CommunityCardsPanel" Orientation="Horizontal" 
                                HorizontalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>
                
                <!-- Player Area -->
                <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Player Hand Value -->
                    <Border x:Name="PlayerValueBadge" Background="#40000000" CornerRadius="15" 
                            Padding="15,6" Margin="0,0,0,10" HorizontalAlignment="Center"
                            Visibility="Collapsed">
                        <TextBlock x:Name="PlayerHandValue" Text="0" FontSize="16"
                                   Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                    
                    <!-- Player Cards -->
                    <StackPanel x:Name="PlayerCardsPanel" Orientation="Horizontal" 
                                HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="Y O U R   H A N D" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0" FontWeight="Medium"/>
                </StackPanel>
            </Grid>
            
            <!-- Multiplayer Seats (Poker Mode) -->
            <Canvas x:Name="MultiplayerSeats" Visibility="Collapsed">
                <!-- Seats will be added dynamically -->
            </Canvas>
        </Grid>
        
        <!-- Bottom Control Panel -->
        <Border Grid.Row="2" Background="#20FFFFFF" Padding="30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Chip Selection (Betting) -->
                <StackPanel x:Name="BettingPanel" Grid.Column="0" Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <Button x:Name="Chip10" Style="{StaticResource ChipButton}" Background="#E74C3C"
                            Margin="5" Click="ChipButton_Click" Tag="10">
                        <TextBlock Text="10" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </Button>
                    <Button x:Name="Chip25" Style="{StaticResource ChipButton}" Background="#27AE60"
                            Margin="5" Click="ChipButton_Click" Tag="25">
                        <TextBlock Text="25" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </Button>
                    <Button x:Name="Chip50" Style="{StaticResource ChipButton}" Background="#3498DB"
                            Margin="5" Click="ChipButton_Click" Tag="50">
                        <TextBlock Text="50" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </Button>
                    <Button x:Name="Chip100" Style="{StaticResource ChipButton}" Background="#9B59B6"
                            Margin="5" Click="ChipButton_Click" Tag="100">
                        <TextBlock Text="100" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </Button>
                    <Button x:Name="Chip500" Style="{StaticResource ChipButton}" Background="#F39C12"
                            Margin="5" Click="ChipButton_Click" Tag="500">
                        <TextBlock Text="500" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </Button>
                </StackPanel>
                
                <!-- Current Bet Display and Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Current Bet -->
                    <Border Background="#30D4AF37" CornerRadius="10" Padding="20,10" 
                            Margin="0,0,20,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="BET: " FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="CurrentBetDisplay" Text="$0" FontSize="20"
                                       Foreground="{StaticResource GoldAccentBrush}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Deal Button (Betting Phase) -->
                    <Button x:Name="DealButton" Content="DEAL" Style="{StaticResource PremiumButton}"
                            Width="120" Margin="5" Click="DealButton_Click" IsEnabled="False"/>
                    
                    <!-- Game Action Buttons -->
                    <StackPanel x:Name="ActionButtonsPanel" Orientation="Horizontal" Visibility="Collapsed">
                        <Button x:Name="HitButton" Content="HIT" Style="{StaticResource GameActionButton}"
                                Margin="5" Click="HitButton_Click"/>
                        <Button x:Name="StandButton" Content="STAND" Style="{StaticResource GameActionButton}"
                                Margin="5" Click="StandButton_Click"/>
                        <Button x:Name="DoubleButton" Content="DOUBLE" Style="{StaticResource GameActionButton}"
                                Margin="5" Click="DoubleButton_Click"/>
                    </StackPanel>
                    
                    <!-- New Game Button -->
                    <Button x:Name="NewGameButton" Content="NEW GAME" Style="{StaticResource PremiumButton}"
                            Width="140" Margin="5" Click="NewGameButton_Click" Visibility="Collapsed"/>
                </StackPanel>
                
                <!-- Right Side - Clear Bet and History -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="ClearBetButton" Content="Clear Bet" Style="{StaticResource SecondaryButton}"
                            Margin="5" Click="ClearBetButton_Click"/>
                    <Button x:Name="HistoryButton" Content="📜 History" Style="{StaticResource SecondaryButton}"
                            Margin="5" Click="HistoryButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Result Overlay -->
        <Border x:Name="ResultOverlay" Grid.RowSpan="3" Background="#90000000" 
                Visibility="Collapsed">
            <Border Background="#20FFFFFF" CornerRadius="20" Padding="50,30"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="400">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="ResultEmoji" Text="🎉" FontSize="60" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ResultTitle" Text="YOU WIN!" FontSize="32" FontWeight="Light"
                               Foreground="{StaticResource GoldAccentBrush}" HorizontalAlignment="Center"
                               Margin="0,10,0,5"/>
                    <TextBlock x:Name="ResultAmount" Text="+$100" FontSize="24" 
                               Foreground="#50C878" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    <Button Content="CONTINUE" Style="{StaticResource PremiumButton}" 
                            Margin="0,25,0,0" Click="ContinueButton_Click"/>
                </StackPanel>
            </Border>
        </Border>
        
        <!-- History Panel -->
        <Border x:Name="HistoryPanel" Grid.RowSpan="3" Background="#E0000000" 
                Visibility="Collapsed">
            <Border Background="#161B22" Width="350" HorizontalAlignment="Right" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Game History" FontSize="18" Foreground="White" 
                                   FontWeight="Medium" VerticalAlignment="Center"/>
                        <Button Content="✕" Background="Transparent" Foreground="White" 
                                BorderThickness="0" FontSize="18" HorizontalAlignment="Right"
                                Margin="150,0,0,0" Cursor="Hand" Click="CloseHistoryButton_Click"/>
                    </StackPanel>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="HistoryList">
                            <!-- History items will be added dynamically -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Border>
        
        <!-- Chat Panel (Optional) -->
        <Border x:Name="ChatPanel" Grid.Row="1" Width="280" HorizontalAlignment="Right" 
                Margin="0,20,20,20" Background="#20FFFFFF" CornerRadius="15" 
                Visibility="Collapsed">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="💬 Chat" FontSize="14" Foreground="White" 
                           FontWeight="Medium" Margin="0,0,0,10"/>
                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ChatMessages"/>
                </ScrollViewer>
                
                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ChatInput" Style="{StaticResource PremiumTextBox}" 
                             Padding="10,8"/>
                    <Button Grid.Column="1" Content="➤" Background="{StaticResource GoldAccentBrush}"
                            Foreground="Black" FontSize="14" Padding="12,8" Margin="5,0,0,0"
                            BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
