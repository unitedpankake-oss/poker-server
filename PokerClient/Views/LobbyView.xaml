<UserControl x:Class="BlackjackGame.Views.LobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/CasinoStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1117" Offset="0"/>
                <GradientStop Color="#161B22" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <Grid MaxWidth="900" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,30">
                <TextBlock Text="♠ GAME LOBBY ♠" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource GoldAccentBrush}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ConnectionStatus" Text="Connecting..." FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock Text="Logged in as: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                    <TextBlock x:Name="UsernameDisplay" Text="" Foreground="White" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text=" | Balance: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                    <TextBlock x:Name="BalanceDisplay" Text="" Foreground="{StaticResource GoldAccentBrush}" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
            
            <!-- Server Connection -->
            <Border Grid.Row="1" Background="#20FFFFFF" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Server Address" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="ServerAddressBox" Text="http://localhost:5000/gamehub" 
                                 Style="{StaticResource PremiumTextBox}" Width="400" HorizontalAlignment="Left"/>
                    </StackPanel>
                    
                    <Button x:Name="ConnectButton" Grid.Column="1" Content="CONNECT" 
                            Style="{StaticResource PremiumButton}" Width="120" VerticalAlignment="Bottom"
                            Click="ConnectButton_Click"/>
                </Grid>
            </Border>
            
            <!-- Rooms List -->
            <Border Grid.Row="2" Background="#20FFFFFF" CornerRadius="10" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Available Rooms" FontSize="18" FontWeight="Bold" 
                                   Foreground="White" VerticalAlignment="Center"/>
                        <Button x:Name="RefreshButton" Content="↻ Refresh" 
                                Style="{StaticResource SecondaryButton}" Margin="20,0,0,0"
                                Click="RefreshButton_Click" IsEnabled="False"/>
                    </StackPanel>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="RoomsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#30FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                                            MouseLeftButtonDown="RoomItem_Click" Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding RoomName}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                                    <Border Background="#40D4AF37" CornerRadius="8" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ModeName}" FontSize="10" Foreground="{StaticResource GoldAccentBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <TextBlock Text="Min Bet: $" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                                    <TextBlock Text="{Binding MinBet}" Foreground="{StaticResource GoldAccentBrush}" FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="1" Margin="20,0">
                                                <TextBlock HorizontalAlignment="Center" Foreground="White" FontSize="14">
                                                    <Run Text="{Binding PlayerCount}"/><Run Text="/"/><Run Text="{Binding MaxPlayers}"/>
                                                </TextBlock>
                                                <TextBlock Text="Players" Foreground="{StaticResource TextSecondaryBrush}" 
                                                           FontSize="11" HorizontalAlignment="Center"/>
                                                <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,2,0,0">
                                                    <Run Text="👁 "/><Run Text="{Binding SpectatorCount}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="🗑" Style="{StaticResource SecondaryButton}"
                                                        Width="35" Tag="{Binding RoomId}" Click="DeleteRoom_Click" Margin="0,0,5,0"
                                                        ToolTip="Delete Room"/>
                                                <Button Content="👁 WATCH" Style="{StaticResource SecondaryButton}"
                                                        Width="80" Tag="{Binding RoomId}" Click="WatchRoom_Click" Margin="0,0,5,0"/>
                                                <Button Content="JOIN" Style="{StaticResource PremiumButton}"
                                                        Width="80" Tag="{Binding RoomId}" Click="JoinRoom_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <TextBlock x:Name="NoRoomsMessage" Grid.Row="1" Text="No rooms available. Create one!" 
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                </Grid>
            </Border>
            
            <!-- Create Room / Back -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="SINGLE PLAYER" Style="{StaticResource SecondaryButton}"
                        Width="140" Click="SinglePlayerButton_Click"/>
                <Button x:Name="CreateRoomButton" Content="CREATE ROOM" Style="{StaticResource PremiumButton}"
                        Width="150" Margin="15,0,0,0" Click="CreateRoomButton_Click" IsEnabled="False"/>
                <Button Content="BACK" Style="{StaticResource SecondaryButton}" Width="100" 
                        Margin="15,0,0,0" Click="BackButton_Click"/>
            </StackPanel>
        </Grid>
        
        <!-- Create Room Dialog -->
        <Border x:Name="CreateRoomDialog" Background="#80000000" Visibility="Collapsed">
            <Border Background="#1E2328" CornerRadius="15" Padding="30" 
                    MaxWidth="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Create New Room" FontSize="20" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Room Name" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="NewRoomNameBox" Style="{StaticResource PremiumTextBox}"/>
                    
                    <TextBlock Text="Minimum Bet" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,15,0,5"/>
                    <ComboBox x:Name="MinBetCombo" SelectedIndex="1">
                        <ComboBoxItem Content="$10"/>
                        <ComboBoxItem Content="$25"/>
                        <ComboBoxItem Content="$50"/>
                        <ComboBoxItem Content="$100"/>
                    </ComboBox>
                    
                    <TextBlock Text="Game Mode" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,15,0,5"/>
                    <Border Background="#20FFFFFF" CornerRadius="20" Padding="4">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <RadioButton x:Name="BlackjackMode" Content="♠ Blackjack" IsChecked="True"
                                         Style="{StaticResource ModeToggleButton}" GroupName="GameMode"/>
                            <RadioButton x:Name="PokerMode" Content="♦ Poker"
                                         Style="{StaticResource ModeToggleButton}" GroupName="GameMode"/>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                        <Button Content="CREATE" Style="{StaticResource PremiumButton}" Width="100"
                                Click="ConfirmCreateRoom_Click"/>
                        <Button Content="CANCEL" Style="{StaticResource SecondaryButton}" Width="100"
                                Margin="15,0,0,0" Click="CancelCreateRoom_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
