<UserControl x:Class="BlackjackGame.Views.MultiplayerGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BlackjackGame.Views">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/CasinoStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Card Deal Animation -->
            <Storyboard x:Key="CardDealAnimation">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                                 From="-50" To="0" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            
            <!-- Pulse Animation -->
            <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.5" To="1" Duration="0:0:0.8" AutoReverse="True"/>
            </Storyboard>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid x:Name="MainGrid">
        <!-- Dark Background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1117" Offset="0"/>
                <GradientStop Color="#161B22" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#20FFFFFF" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Room Info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#20D4AF37" CornerRadius="20" Padding="15,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="♠" FontSize="16" Foreground="{StaticResource GoldAccentBrush}" Margin="0,0,8,0"/>
                            <TextBlock x:Name="RoomNameDisplay" Text="MULTIPLAYER" FontSize="14" 
                                       Foreground="{StaticResource GoldAccentBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Game Message -->
                <Border Grid.Column="1" Background="#50000000" CornerRadius="10" Padding="25,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="GameMessage" Text="Waiting for players..." FontSize="18"
                                   Foreground="{StaticResource GoldAccentBrush}" FontWeight="Medium"/>
                        <!-- Turn Timer -->
                        <Border x:Name="TimerBorder" Background="#80E74C3C" CornerRadius="15" 
                                Padding="12,4" Margin="15,0,0,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏱" FontSize="14" Foreground="White" Margin="0,0,5,0"/>
                                <TextBlock x:Name="TimerText" Text="30" FontSize="16" 
                                           Foreground="White" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- User Info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Balance -->
                    <Border Background="#20D4AF37" CornerRadius="20" Padding="15,8" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock x:Name="BalanceDisplay" Text="$1,000" FontSize="14"
                                       Foreground="{StaticResource GoldAccentBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Leave Button -->
                    <Button x:Name="LeaveButton" Content="↩ LEAVE" Style="{StaticResource SecondaryButton}" 
                            Padding="15,8" Click="LeaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Game Table Area -->
        <Grid Grid.Row="1" Margin="40">
            <!-- Poker Table (Ellipse) -->
            <Ellipse x:Name="TableSurface" Stretch="Fill" Margin="20">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" 
                                         RadiusX="0.6" RadiusY="0.6">
                        <GradientStop Color="#1E8B5E" Offset="0"/>
                        <GradientStop Color="#0D4F3C" Offset="0.7"/>
                        <GradientStop Color="#082A20" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <DropShadowEffect Color="#50C878" BlurRadius="50" ShadowDepth="0" Opacity="0.3"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <!-- Table Border -->
            <Ellipse Stretch="Fill" Margin="20" StrokeThickness="8">
                <Ellipse.Stroke>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#5D4037" Offset="0"/>
                        <GradientStop Color="#8D6E63" Offset="0.5"/>
                        <GradientStop Color="#5D4037" Offset="1"/>
                    </LinearGradientBrush>
                </Ellipse.Stroke>
            </Ellipse>
            
            <!-- Inner Table Rim -->
            <Ellipse Stretch="Fill" Margin="35" Stroke="#30D4AF37" StrokeThickness="2" 
                     StrokeDashArray="10,5"/>
            
            <!-- Game Content -->
            <Grid x:Name="GameContent" Margin="60">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Other Players / Dealer Area -->
                <Grid Grid.Row="0">
                    <!-- Dealer/Community Cards -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <TextBlock x:Name="DealerLabel" Text="D E A L E R" FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,10" FontWeight="Medium"/>
                        
                        <StackPanel x:Name="DealerCardsPanel" Orientation="Horizontal" HorizontalAlignment="Center"/>
                        
                        <Border x:Name="DealerValueBadge" Background="#40000000" CornerRadius="15" 
                                Padding="15,6" Margin="0,10,0,0" HorizontalAlignment="Center" Visibility="Collapsed">
                            <TextBlock x:Name="DealerValueText" Text="0" FontSize="16" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    
                    <!-- Other Players Display (positioned around table) -->
                    <StackPanel x:Name="OtherPlayersPanel" Orientation="Horizontal" HorizontalAlignment="Center" 
                                VerticalAlignment="Top" Margin="0,10,0,0"/>
                </Grid>
                
                <!-- Center Area (Pot, Message) -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Pot Display (Poker) -->
                    <Border x:Name="PotDisplay" Background="#40000000" CornerRadius="20" 
                            Padding="30,12" Margin="0,10" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰 POT: " FontSize="18" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="PotAmount" Text="$0" FontSize="22" 
                                       Foreground="{StaticResource GoldAccentBrush}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Player Area -->
                <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border x:Name="PlayerValueBadge" Background="#40000000" CornerRadius="15" 
                            Padding="15,6" Margin="0,0,0,10" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock x:Name="PlayerValueText" Text="0" FontSize="16" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                    
                    <StackPanel x:Name="PlayerCardsPanel" Orientation="Horizontal" HorizontalAlignment="Center"/>
                    
                    <TextBlock x:Name="PlayerLabel" Text="Y O U R   H A N D" FontSize="12" 
                               Foreground="{StaticResource GoldAccentBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0" FontWeight="Medium"/>
                </StackPanel>
            </Grid>
        </Grid>
        
        <!-- Bottom Control Panel -->
        <Border Grid.Row="2" Background="#20FFFFFF" Padding="30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Chip Selection (Betting) -->
                <StackPanel x:Name="BettingPanel" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel x:Name="ChipsPanel" Orientation="Horizontal">
                        <Button x:Name="Chip10" Style="{StaticResource ChipButton}" Background="#E74C3C"
                                Margin="5" Click="ChipButton_Click" Tag="10">
                            <TextBlock Text="10" Foreground="White" FontWeight="Bold" FontSize="12"/>
                        </Button>
                        <Button x:Name="Chip25" Style="{StaticResource ChipButton}" Background="#27AE60"
                                Margin="5" Click="ChipButton_Click" Tag="25">
                            <TextBlock Text="25" Foreground="White" FontWeight="Bold" FontSize="12"/>
                        </Button>
                        <Button x:Name="Chip50" Style="{StaticResource ChipButton}" Background="#3498DB"
                                Margin="5" Click="ChipButton_Click" Tag="50">
                            <TextBlock Text="50" Foreground="White" FontWeight="Bold" FontSize="12"/>
                        </Button>
                        <Button x:Name="Chip100" Style="{StaticResource ChipButton}" Background="#9B59B6"
                                Margin="5" Click="ChipButton_Click" Tag="100">
                            <TextBlock Text="100" Foreground="White" FontWeight="Bold" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
                
                <!-- Center Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Current Bet (for Blackjack) -->
                    <Border x:Name="CurrentBetBorder" Background="#30D4AF37" CornerRadius="10" Padding="20,10" Margin="0,0,20,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="BET: " FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="CurrentBetDisplay" Text="$0" FontSize="20"
                                       Foreground="{StaticResource GoldAccentBrush}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Place Bet / Ready Button -->
                    <Button x:Name="PlaceBetButton" Content="PLACE BET" Style="{StaticResource PremiumButton}"
                            Width="140" Margin="5" Click="PlaceBetButton_Click" IsEnabled="True"/>
                    
                    <!-- Blackjack Action Buttons -->
                    <StackPanel x:Name="ActionPanel" Orientation="Horizontal" Visibility="Collapsed">
                        <Button x:Name="HitButton" Content="HIT" Style="{StaticResource GameActionButton}"
                                Margin="5" Click="HitButton_Click"/>
                        <Button x:Name="StandButton" Content="STAND" Style="{StaticResource GameActionButton}"
                                Margin="5" Click="StandButton_Click"/>
                    </StackPanel>
                    
                    <!-- Poker Action Buttons -->
                    <StackPanel x:Name="PokerActionPanel" Orientation="Horizontal" Visibility="Collapsed">
                        <Button x:Name="FoldButton" Content="FOLD" Style="{StaticResource SecondaryButton}"
                                Width="90" Margin="5" Click="FoldButton_Click"/>
                        <Button x:Name="CheckButton" Content="CHECK" Style="{StaticResource SecondaryButton}"
                                Width="90" Margin="5" Click="CheckButton_Click"/>
                        <Button x:Name="CallButton" Content="CALL" Style="{StaticResource PremiumButton}"
                                Width="100" Margin="5" Click="CallButton_Click"/>
                        <Button x:Name="RaiseButton" Content="RAISE" Style="{StaticResource PremiumButton}"
                                Width="100" Margin="5" Click="RaiseButton_Click"/>
                        <Button x:Name="AllInButton" Content="ALL IN" Style="{StaticResource PremiumButton}"
                                Width="100" Margin="5" Click="AllInButton_Click"/>
                    </StackPanel>
                    
                    <!-- New Round Button -->
                    <Button x:Name="NewRoundButton" Content="NEW ROUND" Style="{StaticResource PremiumButton}"
                            Width="150" Margin="5" Click="NewRoundButton_Click" Visibility="Collapsed"/>
                    
                    <!-- Muck/Show Buttons (Showdown) -->
                    <StackPanel x:Name="MuckShowPanel" Orientation="Horizontal" Visibility="Collapsed">
                        <Button x:Name="MuckButton" Content="🂠 MUCK" Style="{StaticResource SecondaryButton}"
                                Width="100" Margin="5" Click="MuckButton_Click" ToolTip="Hide your cards"/>
                        <Button x:Name="ShowButton" Content="🃏 SHOW" Style="{StaticResource PremiumButton}"
                                Width="100" Margin="5" Click="ShowButton_Click" ToolTip="Reveal your cards"/>
                    </StackPanel>
                    
                    <!-- Spectator Controls -->
                    <StackPanel x:Name="SpectatorPanel" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="👁 Watching" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" 
                                   VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <Button x:Name="TakeSeatButton" Content="🪑 TAKE SEAT" Style="{StaticResource PremiumButton}"
                                Width="130" Margin="5" Click="TakeSeatButton_Click"/>
                    </StackPanel>
                    
                    <!-- Stand Up Button (for seated players) -->
                    <Button x:Name="StandUpButton" Content="🚶 STAND UP" Style="{StaticResource SecondaryButton}"
                            Width="120" Margin="5" Click="StandUpButton_Click" Visibility="Collapsed"/>
                    
                    <!-- Waiting Message -->
                    <TextBlock x:Name="WaitingMessage" Text="Waiting for other players..." 
                               FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" 
                               VerticalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>
                
                <!-- Right Side - Clear Bet / Poker Raise -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel x:Name="RaisePanel" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="Raise: $" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" 
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="RaiseAmountBox" Text="20" Width="80" Style="{StaticResource PremiumTextBox}" 
                                 Height="35" Margin="5,0"/>
                    </StackPanel>
                    <TextBlock x:Name="ToCallText" Text="" FontSize="14" 
                               Foreground="{StaticResource GoldAccentBrush}" VerticalAlignment="Center" Margin="10,0"/>
                    <Button x:Name="ClearBetButton" Content="Clear Bet" Style="{StaticResource SecondaryButton}"
                            Margin="5" Click="ClearBetButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Result Overlay -->
        <Border x:Name="ResultOverlay" Grid.RowSpan="3" Background="#90000000" Visibility="Collapsed">
            <Border Background="#20FFFFFF" CornerRadius="20" Padding="50,30"
                    HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="ResultEmoji" Text="🎉" FontSize="60" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ResultTitle" Text="YOU WIN!" FontSize="32" FontWeight="Light"
                               Foreground="{StaticResource GoldAccentBrush}" HorizontalAlignment="Center" Margin="0,10,0,5"/>
                    <TextBlock x:Name="ResultMessage" Text="+$100" FontSize="24" 
                               Foreground="#50C878" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    <Button Content="CONTINUE" Style="{StaticResource PremiumButton}" 
                            Margin="0,25,0,0" Click="ContinueButton_Click"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
