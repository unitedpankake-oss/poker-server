<UserControl x:Class="BlackjackGame.Views.CardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="80" Height="112">
    
    <UserControl.Resources>
        <Style x:Key="SuitText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>
    </UserControl.Resources>
    
    <Grid x:Name="CardRoot">
        <!-- Card Face -->
        <Border x:Name="CardFace" CornerRadius="8" Background="White" 
                BorderBrush="#E0E0E0" BorderThickness="1" Visibility="Visible">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="3" 
                                  Direction="315" Opacity="0.4"/>
            </Border.Effect>
            
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Top Left -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Left">
                    <TextBlock x:Name="ValueTopLeft" FontSize="16" FontWeight="Bold" 
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="SuitTopLeft" Style="{StaticResource SuitText}" 
                               HorizontalAlignment="Center" Margin="0,-4,0,0"/>
                </StackPanel>
                
                <!-- Center Suit -->
                <TextBlock x:Name="SuitCenter" Grid.Row="1" 
                           FontFamily="Segoe UI Symbol" FontSize="36"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                
                <!-- Bottom Right (Inverted) -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Right" 
                            RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <RotateTransform Angle="180"/>
                    </StackPanel.RenderTransform>
                    <TextBlock x:Name="ValueBottomRight" FontSize="16" FontWeight="Bold" 
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="SuitBottomRight" Style="{StaticResource SuitText}" 
                               HorizontalAlignment="Center" Margin="0,-4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Card Back -->
        <Border x:Name="CardBack" CornerRadius="8" BorderBrush="#D4AF37" 
                BorderThickness="2" Visibility="Collapsed">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A237E" Offset="0"/>
                    <GradientStop Color="#283593" Offset="0.5"/>
                    <GradientStop Color="#1A237E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="3" 
                                  Direction="315" Opacity="0.4"/>
            </Border.Effect>
            
            <Grid>
                <!-- Decorative Pattern -->
                <Border CornerRadius="6" Margin="8" BorderBrush="#40D4AF37" BorderThickness="1">
                    <Grid>
                        <Path Data="M0,0 L60,84 M60,0 L0,84" Stroke="#30D4AF37" StrokeThickness="1"/>
                        <Ellipse Width="30" Height="30" Stroke="#50D4AF37" StrokeThickness="1"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Text="♠" FontFamily="Segoe UI Symbol" FontSize="20"
                                   Foreground="#60D4AF37" HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
